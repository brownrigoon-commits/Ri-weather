{"ciCode": 100000723, "ccName": "클럽디보은", "detail": {"ciCode": 100000723, "ccName": "클럽디보은", "createdAt": "Y", "country": 1, "district": 3, "address": "충북 보은군 보은읍 장속중초로 386", "tel": "043-540-8888", "fax": "043-540-8889", "homepageUrl": "https://www.clubd.co.kr/", "description": "<p><span style=\"font-size: 10pt; color: rgb(51, 153, 0);\"><b style=\"\">&quot;광활한 자연 본연의 아름다움, 클럽디 보은&quot;</b></span></p>\n\n<div style=\"color: rgb(0, 0, 0);\"><span style=\"font-size: 10pt;\">독수리가 날개를 펼치듯 광활한 전경으로 자연 본연의 모습 그대로 홀을 만들고</span></div>\n\n<div style=\"color: rgb(0, 0, 0);\"><span style=\"font-size: 10pt;\">자연 계곡 그대로 이용하여 자연 계류와 연못을 재생하였습니다.</span></div>\n\n<div style=\"color: rgb(0, 0, 0);\"><span style=\"font-size: 10pt;\">모든 홀은 전략적인 레이아웃으로 샷 밸류가 살아있으며, 홀과 홀 사이의 간섭이 없는 코스입니다.</span></div>\n", "difficultyGreen": 7, "difficultyCc": 4, "ciStatus": 1, "ciOption": 14, "areaName": "충청도", "logoImage": "http://uf.gzcdn.net/course/info/202311/2818/53/e0b680761318430289d087ecb0be123f.jpg", "holeCount": 18, "parCount": 72, "totalWidth": 6153, "boardCount": 1, "ci3d": "Y", "isOnlyHd": null, "isVisionPlus": "Y", "isNgs": "Y", "isOnlyNgs": null, "isTvnx": "Y", "isNxp": "Y", "ciVersion": 2, "tourCc": 0, "ciNight": 0, "membership": "N", "realityYn": "N", "difficultyYn": "N"}, "holeInfo": {"holeInfoList": [[{"backTee": 489, "basicPar": 5, "ccMasterSeq": 785, "champTee": 474, "ciCode": 100000723, "ciNum": 1, "ciVersion": 2, "courseTypeOrder": 1, "description": "", "frontTee": 453, "heightBackTee": -18.69, "heightChampTee": -18.11, "heightFrontTee": -17.91, "heightLadySeniorTee": 0.0, "heightLadyTee": -16.35, "heightSeniorTee": -16.35, "holeNo": 1, "ladySeniorTee": 0, "ladyTee": 391, "mapUrl": "/yardage/entire/yardage_entire_785_01_01.jpg", "oCcMasterSeq": null, "oCiNum": null, "screenshot": "", "seniorTee": 396, "videoMapUrl": "hole3D_785_01_01"}, {"backTee": 365, "basicPar": 4, "ccMasterSeq": 785, "champTee": 349, "ciCode": 100000723, "ciNum": 1, "ciVersion": 2, "courseTypeOrder": 1, "descri