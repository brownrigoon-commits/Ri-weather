 페어웨이 우측으로 하고 세컨샷 또한 우측 페어웨이 벙커 방향으로 하면 그린으로의 방향이 좋아집니다. 그린 중앙이 높아 핀이 앞쪽에 위치할 경우 조금 길게 치는 것이 좋습니다.", "frontTee": 481, "heightBackTee": -7.26, "heightChampTee": -7.2, "heightFrontTee": -4.67, "heightLadySeniorTee": 0.0, "heightLadyTee": -4.26, "heightSeniorTee": -4.65, "holeNo": 2, "ladySeniorTee": 0, "ladyTee": 443, "mapUrl": "/yardage/entire/yardage_entire_374_01_02.jpg", "oCcMasterSeq": null, "oCiNum": null, "screenshot": "screenshot_100000049_1_02.jpg", "seniorTee": 465, "videoMapUrl": "hole3D_374_01_02"}, {"backTee": 468, "basicPar": 4, "ccMasterSeq": 374, "champTee": 438, "ciCode": 100000049, "ciNum": 1, "ciVersion": 2, "courseTypeOrder": 1, "description": "가장 긴 파4홀이면서 약간 오르막홀 입니다. 티샷 랜딩지점까지는 페어웨이에 벙커가 없지만 세컨샷부터는 벙커들과 힘겨운 승부를 해야 할 것 입니다. 장타자들이라도 그린 주위의 벙커를 쉽게 피해 갈 수 없으므로 정확한 샷만이 이 홀의 스코어를 좌우합니다.", "frontTee": 413, "heightBackTee": -11.55, "heightChampTee": -5.91, "heightFrontTee": -2.78, "heightLadySeniorTee": 0.0, "heightLadyTee": 3.26, "heightSeniorTee": 0.33, "holeNo": 3, "ladySeniorTee": 0, "ladyTee": 340, "mapUrl": "/yardage/entire/yardage_entire_374_01_03.jpg", "oCcMasterSeq": null, "oCiNum": null, "screenshot": "screenshot_100000049_1_03.jpg", "seniorTee": 390, "videoMapUrl": "hole3D_374_01_03"}, {"backTee": 170, "basicPar": 3, "ccMasterSeq": 374, "champTee": 150, "ciCode": 100000049, "ciNum": 1, "ciVersion": 2, "courseTypeOrder": 1, "description": "팜파스코스의 시그너쳐 홀로써 티에 서면 연못과 대형 벙커, 그린이 한눈에 들어오는 아름다운 아일랜드 홀 입니다. 대형벙커가 그린을 감싸고 있어 심리적으로 부담이 크고, 핀의 위치에 따라 공략이 다르며 그린 또한 쉽지 않기 때문에 정확한 거리감과 방향성을 요구합니다", "frontTee": 141, "heightBackTee": -11.63, "heightChampTee": -8.45, "heightFrontTee": -8.34, "heightLadySeniorTee": 0.0, "heightLadyTee": -2.88, "heightSeniorTee": -6.59, "holeNo": 4, "ladySeniorTee": 0, "ladyTee": 89, "mapUrl": "/yardage/entire/yardage_entire_374_01_04.jpg", "oCcMasterSeq": null, "oCiNum": null, "screenshot": "screenshot_100000049_1_04.jpg", "seniorTee": 123, "videoMapUrl": "hole3D_374_01_04"}, {"backTee": 585, "basicPar": 5, "ccMasterSeq": 374,