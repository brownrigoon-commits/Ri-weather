{"ciCode": 100000776, "ccName": "에버리스 CC - 새별/파인", "detail": {"ciCode": 100000776, "ccName": "에버리스 CC - 새별/파인", "createdAt": "Y", "country": 1, "district": 6, "address": "제주도 제주시 애월읍 평화로 1593-75", "tel": "064-795-5000", "fax": "064-795-5005", "homepageUrl": "www.everis.co.kr", "description": "<div style=\"text-align: center;\">\r\n<div style=\"text-align: left;\"><b><span style=\"font-size: 10pt; color: rgb(51, 153, 0);\">\"제주의 대자연이 속삭이는 솔바람같은 이야기\"</span></b></div>\r\n<div style=\"text-align: left;\"><span style=\"font-size: 10pt;\">동쪽으로 한라산, 서쪽으로 광활한 목초지와 바다, 아름다운 섬 비양도가</span></div>\r\n<div style=\"text-align: left;\"><span style=\"font-size: 10pt;\">그림처럼 펼쳐지는 제주 천혜의 자연환경에 아름다운 조경까지 더해</span></div>\r\n<div style=\"text-align: left;\"><span style=\"font-size: 10pt;\">제주의 자연과 라운드의 즐거움을 함께 느끼는 최적의 골프코스를 선보입니다.</span></div></div>", "difficultyGreen": 3, "difficultyCc": 4, "ciStatus": 1, "ciOption": 14, "areaName": "제주도", "logoImage": "http://uf.gzcdn.net/course/info/202311/2818/59/e157a21449b14bfab2457a8f18852f44.jpg", "holeCount": 18, "parCount": 72, "totalWidth": 5911, "boardCount": 0, "ci3d": "Y", "isOnlyHd": null, "isVisionPlus": "Y", "isNgs": "Y", "isOnlyNgs": null, "isTvnx": "Y", "isNxp": "Y", "ciVersion": 2, "tourCc": 0, "ciNight": 0, "membership": "N", "realityYn": "N", "difficultyYn": "N"}, "holeInfo": {"holeInfoList": [[{"backTee": 379, "basicPar": 4, "ccMasterSeq": 843, "champTee": 365, "ciCode": 100000776, "ciNum": 1, "ciVersion": 2, "courseTypeOrder": 1, "description": "", "frontTee": 350, "heightBackTee": -26.08, "heightChampTee": -25.31, "heightFrontTee": -24.33, "heightLadySeniorTee": 0.0, "heightLadyTee": -20.8, "heightSeniorTee": -21.99, "holeNo": 1, "ladySeniorTee": 0, "ladyTee": 300, "mapUrl": "/yardage/entire/yardage_entire_843_01_01.jpg", "oCcMasterSeq": null, "oCiNum": null, "screenshot": "", "seniorTee": 314, "videoMapUrl": "hole3D_843_01_01"}, {"backTee": 373, "basicPar": 4, "ccMasterSeq": 843, "champTee": 353, "ciCode": 100000776, "ciNum": 1