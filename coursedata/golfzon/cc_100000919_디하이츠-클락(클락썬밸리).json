{"ciCode": 100000919, "ccName": "디하이츠 - 클락 (클락썬밸리)", "detail": {"ciCode": 100000919, "ccName": "디하이츠 - 클락 (클락썬밸리)", "createdAt": "N", "country": 21, "district": 0, "address": "T-304 Jose Abad Santos Avenue Clark, Pampanga, Philippines", "tel": "+63 45-499-5119", "fax": " ", "homepageUrl": "http://www.clarksunvalley.co.kr/ ", "description": "<p style=\"line-height: 18px; font-size: 9pt;\"><strong><span style=\"line-height: 20px; color: rgb(51, 153, 0); font-size: 10pt;\">&quot;필리핀 클락에서 썬밸리 그룹이 운영하는 인기 코스, 디하이츠&rdquo;</span></strong></p>\n\n<p style=\"line-height: 18px;\"><span style=\"line-height: 20px; font-size: 13.3333px;\">필리핀의 전설을 간직한 피나투보의 정글을 끼고 있는 클락 코스는 야자나무와 정글이 함께 어우러져 있어 정글에 온 듯한 느낌을 주며,&nbsp;</span><span style=\"line-height: 20px; font-size: 13.3333px;\">피나투보 산맥에서 이어져 오는 산자락이 클락 자유항을 마주하고 뚝 끊어진 곳에 자리잡은 썬밸리 코스는 아라얏 국립 공원이 한눈에 들어오는 전경을 가지고 있습니다.</span></p>\n", "difficultyGreen": 6, "difficultyCc": 7, "ciStatus": 1, "ciOption": 14, "areaName": "필리핀", "logoImage": "http://uf.spazon.com/course/info/202401/0515/04/e34c2b413683437380d15ad28044f5d3.jpg", "holeCount": 18, "parCount": 72, "totalWidth": 5912, "boardCount": 0, "ci3d": "Y", "isOnlyHd": null, "isVisionPlus": "Y", "isNgs": "Y", "isOnlyNgs": null, "isTvnx": "Y", "isNxp": "Y", "ciVersion": 2, "tourCc": 0, "ciNight": 0, "membership": "N", "realityYn": "N", "difficultyYn": "N"}, "holeInfo": {"holeInfoList": [[{"backTee": 354, "basicPar": 4, "ccMasterSeq": 1204, "champTee": 330, "ciCode": 100000919, "ciNum": 1, "ciVersion": 2, "courseTypeOrder": 1, "description": "", "frontTee": 328, "heightBackTee": -30.6981, "heightChampTee": -28.7498, "heightFrontTee": -28.7498, "heightLadySeniorTee": 0.0, "heightLadyTee": -23.2746, "heightSeniorTee": -23.2746, "holeNo": 1, "ladySeniorTee": 0, "ladyTee": 287, "mapUrl": "/yardage/entire/yardage_entire_1204_01_01.jpg", "oCcMasterSeq": null, "oCiNum": null, "screenshot": "", "seniorTee": 287, "videoMapUrl": "hole3D_1204_01_01"}, {"backTee": 147, "basicPar": 3, "ccMasterSeq"